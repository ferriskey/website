  .il-pulse { animation: il-pulse 3s ease-in-out infinite; transform-box: fill-box; transform-origin: center; }

  /* cursor blink */
  @keyframes il-blink { 0%, 100% { opacity: 0.8; } 50% { opacity: 0; } }
  .il-blink { animation: il-blink 1s step-end infinite; }

  /* --- Trident: OTP digits + badge appear in loop (5s cycle) --- */
  @keyframes tri-d {
    0%       { opacity: 0; }
    6%       { opacity: 1; }
    72%      { opacity: 1; }
    82%, 100% { opacity: 0; }
  }
  .tri-d { opacity: 0; animation: tri-d 5s ease-in-out infinite; }

  @keyframes tri-badge {
    0%, 38%   { opacity: 0; }
    48%       { opacity: 1; }
