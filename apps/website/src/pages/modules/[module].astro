            {mod.slug === 'abyss' && (
              <svg class="w-full max-w-sm il-svg-purple" viewBox="0 0 360 300" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <ellipse cx="180" cy="150" rx="140" ry="110" fill="#8b5cf6" fill-opacity="0.04"/>
                <line x1="75"  y1="150" x2="142" y2="150" stroke="#8b5cf6" stroke-opacity="0.22" stroke-width="1.5" stroke-dasharray="4 3"/>
                <line x1="268" y1="96"  x2="208" y2="127" stroke="#8b5cf6" stroke-opacity="0.22" stroke-width="1.5" stroke-dasharray="4 3"/>
