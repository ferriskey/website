    { slug: 'webhooks', name: 'Webhooks', tagline: 'Event-Driven Extensibility',   color: 'cyan',    iconPath: 'M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 002.25-2.25V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v2.25A2.25 2.25 0 006 10.5zm0 9.75h2.25A2.25 2.25 0 0010.5 18v-2.25a2.25 2.25 0 00-2.25-2.25H6a2.25 2.25 0 00-2.25 2.25V18A2.25 2.25 0 006 20.25zm9.75-9.75H18a2.25 2.25 0 002.25-2.25V6A2.25 2.25 0 0018 3.75h-2.25A2.25 2.25 0 0013.5 6v2.25a2.25 2.25 0 002.25 2.25z', docsHref: '/docs/modules/default/en/webhooks/overview', pills: ['HTTP POST','Event Subscriptions','Custom Headers','Auth Header','Real-Time Sync','CRM Integration','Slack Notifications','PagerDuty','SIEM Forwarding','Lifecycle Events'], features: [{ title:'Event Subscriptions', desc:'Subscribe to specific events per webhook — user.created, auth.login, client.secret_rotated, and more.' },{ title:'Custom Headers', desc:'Add Authorization, X-Webhook-Secret, or any custom header to authenticate deliveries at the receiving end.' },{ title:'Per-Realm Scope', desc:'Webhooks are scoped to a realm. Each tenant can have its own set of endpoints and subscriptions.' },{ title:'Multiple Endpoints', desc:'Register as many webhooks as needed. The same event fans out to all registered subscribers in parallel.' },{ title:'Last Triggered At', desc:'Each webhook tracks when it last fired — useful for debugging and operational monitoring.' },{ title:'Decoupled Design', desc:'Your app reacts to identity events without polling FerrisKey. Clean event-driven integration.' }], steps: [{ title:'Register webhook', desc:'Create a webhook with a target URL, optional custom headers, and a name. Scoped to a realm.' },{ title:'Subscribe to events', desc:'Add event subscriptions — choose which lifecycle events should trigger the webhook.' },{ title:'Event fires', desc:'A matching event occurs in the realm. FerrisKey builds the payload and dispatches an HTTP POST.' },{ title:'Your system responds', desc:'Your endpoint receives the structured payload and reacts — send an email, sync a CRM, trigger a workflow.' }] },
  ]
  return allModules.map(m => ({ params: { module: m.slug }, props: { mod: m, otherModules: allModules.filter(x => x.slug !== m.slug) } }))
}

const { mod, otherModules } = Astro.props as { mod: Module; otherModules: Module[] }

const colorMap: Record<string, { bg: string; border: string; text: string; pill: string }> = {
  blue:    { bg: 'bg-blue-500/10',    border: 'border-blue-500/30',    text: 'text-blue-400',    pill: 'bg-blue-500/10 text-blue-300 border-blue-500/30' },
  emerald: { bg: 'bg-emerald-500/10', border: 'border-emerald-500/30', text: 'text-emerald-400', pill: 'bg-emerald-500/10 text-emerald-300 border-emerald-500/30' },
  amber:   { bg: 'bg-amber-500/10',   border: 'border-amber-500/30',   text: 'text-amber-400',   pill: 'bg-amber-500/10 text-amber-300 border-amber-500/30' },
  purple:  { bg: 'bg-purple-500/10',  border: 'border-purple-500/30',  text: 'text-purple-400',  pill: 'bg-purple-500/10 text-purple-300 border-purple-500/30' },
  rose:    { bg: 'bg-rose-500/10',    border: 'border-rose-500/30',    text: 'text-rose-400',    pill: 'bg-rose-500/10 text-rose-300 border-rose-500/30' },
  cyan:    { bg: 'bg-cyan-500/10',    border: 'border-cyan-500/30',    text: 'text-cyan-400',    pill: 'bg-cyan-500/10 text-cyan-300 border-cyan-500/30' },
}
const c = colorMap[mod.color]
---

