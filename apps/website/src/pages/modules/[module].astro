    82%, 100% { opacity: 0; }
  }
  .tri-badge { opacity: 0; animation: tri-badge 5s ease-in-out infinite; }

  /* --- SeaWatch + Aegis: rows appear staggered (6s cycle) --- */
  @keyframes sea-row {
    0%       { opacity: 0; }
    5%       { opacity: 1; }
    80%      { opacity: 1; }
    90%, 100% { opacity: 0; }
  }
  .sea-row { opacity: 0; animation: sea-row 6s ease-in-out infinite; }

  /* --- Compass: progress bar + traveling dot (3s cycle) --- */
  @keyframes cmp-prog {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }
  .cmp-prog { transform-origin: left center; transform-box: fill-box; animation: cmp-prog 3s ease-in-out infinite; }

  @keyframes cmp-dot {
    0%   { transform: translateX(0);     opacity: 1; }
    90%  { transform: translateX(300px); opacity: 0.8; }
    91%, 100% { transform: translateX(0); opacity: 0; }
  }
  .cmp-dot { animation: cmp-dot 3s ease-in-out infinite; }

  /* --- Abyss: dots travel from providers → center --- */
  @keyframes aby-d1 {
    0%, 4%   { transform: translate(0, 0);      opacity: 0; }
    8%        { opacity: 1; }
    85%       { transform: translate(67px, 0);   opacity: 0.8; }
    92%, 100% { transform: translate(67px, 0);   opacity: 0; }
  }
  @keyframes aby-d2 {
    0%, 4%   { transform: translate(0, 0);       opacity: 0; }
