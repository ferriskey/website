                <text x="180" y="159" text-anchor="middle" fill="#a78bfa" font-size="11" font-family="sans-serif" font-weight="700">Key</text>
                <circle cx="75"  cy="150" r="27" fill="#8b5cf6" fill-opacity="0.08" stroke="#8b5cf6" stroke-opacity="0.28" stroke-width="1"/>
                <text x="75"  y="147" text-anchor="middle" fill="#a78bfa" font-size="13" font-family="sans-serif" font-weight="700">G</text>
                <text x="75"  y="161" text-anchor="middle" fill="#8b5cf6" fill-opacity="0.55" font-size="8" font-family="sans-serif">Google</text>
                <circle cx="268" cy="96"  r="27" fill="#8b5cf6" fill-opacity="0.08" stroke="#8b5cf6" stroke-opacity="0.28" stroke-width="1"/>
