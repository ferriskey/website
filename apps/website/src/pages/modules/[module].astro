              </a>
              <a href="/modules" class="inline-flex items-center gap-2 rounded-lg border px-5 py-2.5 text-sm font-semibold text-foreground hover:bg-muted transition-colors">
                All modules
              </a>
            </div>
          </div>

          <!-- Col 2: SVG illustration -->
          <div class="relative flex items-center justify-center py-8 lg:py-0">

