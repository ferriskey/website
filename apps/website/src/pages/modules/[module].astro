            <h1 class="text-5xl sm:text-6xl font-bold text-foreground tracking-tight">{mod.name}</h1>
            <p class="text-xl text-muted-foreground leading-relaxed text-balance">{mod.description}</p>
            <div class="flex flex-wrap gap-3 pt-2">
