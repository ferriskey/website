<script>
  function initWhyNowTabs() {
    const tabsRoot = document.getElementById('why-now-tabs')
    if (!tabsRoot) return
    const buttons = Array.from(tabsRoot.querySelectorAll<HTMLButtonElement>('[data-view-button]'))
    const panes   = Array.from(document.querySelectorAll<HTMLElement>('[data-view-pane]'))

    function activate(view: string) {
      buttons.forEach((b) => {
        const isActive = b.getAttribute('data-view-button') === view
        b.setAttribute('aria-selected', isActive ? 'true' : 'false')
        b.classList.toggle('bg-white/10', isActive)
        b.classList.toggle('text-white', isActive)
        b.classList.toggle('text-white/55', !isActive)
        b.classList.toggle('hover:text-white', !isActive)
      })
      panes.forEach((p) => {
        const isActive = p.getAttribute('data-view-pane') === view
        p.classList.toggle('hidden', !isActive)
        // Make sure the newly visible pane is "in" (already animated in or trigger it)
        if (isActive) p.classList.add('in')
      })
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const view = btn.getAttribute('data-view-button')
        if (view) activate(view)
      })
    })

    // Sync initial active button visuals (default = custom)
    const initial = buttons.find((b) => b.getAttribute('aria-selected') === 'true')?.getAttribute('data-view-button') ?? 'custom'
    activate(initial)
  }

  initWhyNowTabs()
  document.addEventListener('astro:after-swap', initWhyNowTabs)
</script>
