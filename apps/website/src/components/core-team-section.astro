---
const team = [
  {
    name: 'Nathael Bonnal',
    role: 'Co-Founder & Software Engineer',
    avatar: "/core/nathael.jpeg",
    github: 'https://github.com/nathaelb',
    twitter: null,
  },
  {
    name: 'Baptiste Parmantier',
    role: 'Co-Founder & Software Engineer',
    avatar: "/core/baptiste.jpeg",
    github: 'https://github.com/leadcodedev',
    twitter: null,
  },
  {
    name: 'Guillaume Leroy',
    role: 'Platform Engineer',
    avatar: "/core/guillaume.jpeg",
    github: 'https://github.com/leroyguillaume',
    twitter: null,
  },
  {
    name: 'Joris Vilardell',
    role: 'Software Engineer',
    avatar: '/core/joris.jpeg',
    github: 'https://github.com/jorisvilardell',
    twitter: null,
  },
  {
    name: 'Luis Rubiera',
    role: 'CTO @ Cloud-IAM',
    avatar: '/core/luis.jpeg',
    github: 'https://github.com/luisRubiera',
    twitter: null
  }
]
---

<div class="w-full py-16 sm:py-24 lg:py-32">
  <div class="relative w-full max-w-7xl mx-auto px-5">

    <div class="mb-12" data-anim="fade-up">
      <p class="text-sm font-semibold text-primary uppercase tracking-wide mb-3" data-t="team.label">Team</p>
      <h2 class="text-3xl font-semibold text-foreground sm:text-4xl" data-t="team.title">Meet the core team</h2>
      <p class="mt-4 text-lg text-muted-foreground max-w-2xl text-balance" data-t="team.description">
        The people behind Ferriskey — building secure identity infrastructure in the open.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {team.map((member, i) => (
        <div data-anim="fade-up" style={`transition-delay:${i * 80}ms`} class="group flex flex-col gap-4 border rounded-2xl p-6 bg-background hover:bg-muted/30 transition-colors">
          <img
            src={member.avatar}
            alt={member.name}
            width="64"
            height="64"
            class="size-16 rounded-xl object-cover"
          />
          <div class="flex-1">
            <p class="font-semibold text-foreground text-sm">{member.name}</p>
            <p class="text-xs text-muted-foreground mt-0.5 leading-snug">{member.role}</p>
          </div>
          <div class="flex items-center gap-3">
            {member.github && (
              <a
                href={member.github}
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted-foreground hover:text-foreground transition-colors"
                aria-label={`${member.name} on GitHub`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
              </a>
            )}
            {member.twitter && (
              <a
                href={member.twitter}
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted-foreground hover:text-foreground transition-colors"
                aria-label={`${member.name} on X`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.737-8.835L1.254 2.25H8.08l4.258 5.635 5.906-5.635zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</div>
