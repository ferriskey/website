---
import { Icon } from "@iconify/react";
import { Button } from "@explainer/ui";

interface Props {
  docsHref?: string;
}
const { docsHref = '/' } = Astro.props;
---

<div class="w-full max-w-7xl mx-auto px-5 py-16 sm:py-24 lg:py-32">
  <div
    class="relative overflow-hidden border rounded-2xl bg-primary/5 px-8 py-16 sm:px-16 sm:py-20 text-center"
  >
    <!-- Decorative circles -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div
        class="absolute -top-16 -left-16 w-56 h-56 rounded-full border-2 border-primary/10"
      >
      </div>

      <div
        class="absolute -bottom-20 -right-20 w-64 h-64 rounded-full border-2 border-primary/10"
      >
      </div>
      <div
        class="absolute -bottom-12 -right-12 w-44 h-44 rounded-full border border-primary/[0.07]"
      >
      </div>

      <div class="absolute top-8 right-1/4 size-2.5 rounded-full bg-primary/10">
      </div>
      <div
        class="absolute bottom-10 left-[30%] size-2 rounded-full bg-primary/8"
      >
      </div>
    </div>
    <h2 class="text-3xl font-semibold text-foreground sm:text-4xl" data-t="cta.title">
      Your identity layer, your rules.
    </h2>
    <p class="mt-4 text-lg text-muted-foreground max-w-xl mx-auto text-balance" data-t="cta.description">
      Self-hosted, Apache 2.0, built in Rust. Deploy Ferriskey in minutes and own your authentication stack — no vendor, no lock-in.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Button size="lg" className="cursor-pointer" client:load>
        <a href={docsHref} class="flex gap-2" rel="noopener noreferrer">
          <span data-t="cta.primary">Get started</span>
          <Icon icon="mdi:arrow-right" aria-hidden="true" className="size-5" client:load />
        </a>
      </Button>
      <a
        href="https://github.com/ferriskey/ferriskey"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border px-5 py-2.5 text-sm font-semibold text-foreground hover:bg-muted transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        <span data-t="cta.github">View on GitHub</span>
      </a>
    </div>
  </div>
</div>
