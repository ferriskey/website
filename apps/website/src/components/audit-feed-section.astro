---
// Live audit feed — a self-animating mock of FerrisKey audit events
// No backend; deterministic-ish rotation driven by a small JS loop.

interface AuditEvent {
  kind: 'oidc' | 'mfa' | 'token' | 'fed' | 'role' | 'audit' | 'passkey' | 'warn' | 'logout'
  message: string
  realm: string
  latency: string // "12 ms" or "blocked"
}

// Initial set rendered server-side so the feed isn't empty on first paint
const initialEvents: AuditEvent[] = [
  { kind: 'oidc',    message: 'alice@acme.com signed in via Google',          realm: 'acme',   latency: '12 ms' },
  { kind: 'mfa',     message: 'bob@globex.com authenticated with WebAuthn',   realm: 'globex', latency: '8 ms'  },
  { kind: 'token',   message: 'service:billing received access_token',        realm: 'acme',   latency: '4 ms'  },
  { kind: 'role',    message: 'admin granted editor → carol@globex.com',      realm: 'globex', latency: '11 ms' },
  { kind: 'fed',     message: 'alice@acme.com linked Google identity',        realm: 'acme',   latency: '87 ms' },
  { kind: 'audit',   message: 'charlie@acme.com viewed user list',            realm: 'acme',   latency: '3 ms'  },
  { kind: 'warn',    message: '3 failed logins for eve@acme.com',             realm: 'acme',   latency: 'blocked' },
  { kind: 'passkey', message: 'dan@acme.com registered a passkey',            realm: 'acme',   latency: '145 ms' },
]

// Larger pool used by the JS rotation (kept identical to initial for variety)
const rotationPool: AuditEvent[] = [
  ...initialEvents,
  { kind: 'oidc',    message: 'refresh_token rotated for app:cli',            realm: 'acme',   latency: '6 ms'  },
  { kind: 'logout',  message: 'user logged out from app:dashboard',           realm: 'globex', latency: '2 ms'  },
  { kind: 'oidc',    message: 'pierre@acme.com signed in (password)',         realm: 'acme',   latency: '19 ms' },
  { kind: 'mfa',     message: 'TOTP verified for sarah@globex.com',           realm: 'globex', latency: '5 ms'  },
  { kind: 'token',   message: 'introspect(token) → active for app:web',       realm: 'acme',   latency: '2 ms'  },
  { kind: 'role',    message: 'role:billing-admin assigned to ops-team',      realm: 'acme',   latency: '14 ms' },
  { kind: 'fed',     message: 'sso:saml linked from corp.example.com',        realm: 'globex', latency: '63 ms' },
  { kind: 'warn',    message: 'access_token reuse detected · revoked',        realm: 'acme',   latency: 'blocked' },
  { kind: 'passkey', message: 'lucas@globex.com replaced primary passkey',    realm: 'globex', latency: '92 ms' },
  { kind: 'oidc',    message: 'device_code flow completed for cli',           realm: 'acme',   latency: '34 ms' },
]

// Map kind → tag style (theme-aware via dark: variants)
const KIND_STYLE: Record<AuditEvent['kind'], { label: string; cls: string }> = {
  oidc:    { label: 'OIDC',    cls: 'bg-sky-500/15 text-sky-700 dark:text-sky-300 border-sky-500/30' },
  mfa:     { label: 'MFA',     cls: 'bg-emerald-500/15 text-emerald-700 dark:text-emerald-300 border-emerald-500/30' },
  token:   { label: 'TOKEN',   cls: 'bg-primary/15 text-primary border-primary/30' },
  fed:     { label: 'FED',     cls: 'bg-violet-500/15 text-violet-700 dark:text-violet-300 border-violet-500/30' },
  role:    { label: 'ROLE',    cls: 'bg-amber-500/15 text-amber-700 dark:text-amber-300 border-amber-500/30' },
  audit:   { label: 'AUDIT',   cls: 'bg-muted text-muted-foreground border' },
  passkey: { label: 'PASSKEY', cls: 'bg-fuchsia-500/15 text-fuchsia-700 dark:text-fuchsia-300 border-fuchsia-500/30' },
  warn:    { label: 'WARN',    cls: 'bg-rose-500/15 text-rose-700 dark:text-rose-300 border-rose-500/30' },
  logout:  { label: 'LOGOUT',  cls: 'bg-muted text-muted-foreground border' },
}

const stats = [
  { key: 'eps',     value: '12.4k', label: 'events / sec at p50' },
  { key: 'realms',  value: '∞',     label: 'realms watched in parallel' },
  { key: 'latency', value: '< 5 ms', label: 'audit write p99' },
]
---

<section class="relative w-full py-16 sm:py-24 lg:py-32">
  <div class="relative w-full max-w-7xl mx-auto px-5">

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.4fr] gap-10 lg:gap-16 items-start">

      <!-- Left: header + stats -->
      <div data-anim="fade-up">
        <p class="text-xs sm:text-sm font-semibold text-primary uppercase tracking-widest mb-4 font-mono flex items-center gap-2">
          <span class="relative flex size-2">
            <span class="absolute inline-flex h-full w-full rounded-full bg-primary opacity-60 animate-ping"></span>
            <span class="relative inline-flex size-2 rounded-full bg-primary"></span>
          </span>
          <span data-t="audit.label">Live</span>
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-semibold text-foreground leading-[1.1] mb-6">
          <span data-t="audit.title.lead">Every identity event,</span>{' '}
          <span class="text-primary" data-t="audit.title.accent">streamed and auditable.</span>
        </h2>
        <p class="text-base sm:text-lg text-muted-foreground leading-relaxed mb-8 max-w-md" data-t="audit.description">
          Sign-ins, MFA challenges, token issuance, role changes, federation events — FerrisKey writes them all to one structured stream. Tail it, ship it to your SIEM, or replay it.
        </p>

        <dl class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-1 gap-4 max-w-md">
          {stats.map((s) => (
            <div class="rounded-xl border bg-muted/30 p-4 flex items-center gap-4">
              <dt class="text-2xl sm:text-3xl font-semibold text-primary leading-none font-mono whitespace-nowrap">{s.value}</dt>
              <dd class="text-xs text-muted-foreground leading-snug" data-t={`audit.stat.${s.key}`}>{s.label}</dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- Right: feed card -->
      <div data-anim="fade-up" style="transition-delay:120ms" class="relative">
        <div class="rounded-2xl border bg-card overflow-hidden shadow-xl">

          <!-- Feed header — just 3 dots + connected indicator -->
          <div class="flex items-center justify-between px-5 py-3 border-b bg-muted/30">
            <div class="flex items-center gap-2">
              <span class="size-2.5 rounded-full bg-rose-400/70"></span>
              <span class="size-2.5 rounded-full bg-amber-300/70"></span>
              <span class="size-2.5 rounded-full bg-emerald-400/70"></span>
            </div>
            <div class="hidden sm:flex items-center gap-1.5 text-[10px] font-mono text-muted-foreground uppercase tracking-widest">
              <svg class="size-3 text-emerald-600 dark:text-emerald-400/80" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><circle cx="10" cy="10" r="3"/></svg>
              <span data-t="audit.feed.connected">connected</span>
            </div>
          </div>

          <!-- Feed window: fixed height, clips overflow so the card never resizes -->
          <div id="ferriskey-audit-window" class="audit-window relative overflow-hidden">
            <ul id="ferriskey-audit-feed" class="audit-list" aria-live="polite" aria-relevant="additions" data-pool={JSON.stringify(rotationPool)}>
              {initialEvents.map((evt, i) => {
                const style = KIND_STYLE[evt.kind]
                return (
                  <li class="audit-row flex items-center gap-3 px-5 py-3 border-b border-border/50 last:border-b-0" style={`--row-delay: ${i * 60}ms`}>
                    <span class={`shrink-0 inline-flex items-center justify-center text-[10px] font-semibold font-mono uppercase tracking-wider rounded border px-1.5 py-0.5 min-w-[56px] text-center ${style.cls}`}>
                      {style.label}
                    </span>
                    <span class="flex-1 min-w-0 text-sm text-foreground/85 truncate">{evt.message}</span>
                    <span class="hidden sm:inline-flex items-center gap-1 text-[11px] font-mono text-muted-foreground shrink-0">
                      <span class="text-muted-foreground/70">realm:</span>{evt.realm}
                    </span>
                    <span class={`text-[11px] font-mono shrink-0 tabular-nums ${evt.latency === 'blocked' ? 'text-rose-600 dark:text-rose-300' : 'text-foreground/60'}`}>
                      {evt.latency}
                    </span>
                  </li>
                )
              })}
            </ul>
          </div>

          <!-- Feed footer -->
          <div class="px-5 py-2.5 border-t bg-muted/30 flex items-center justify-between text-[10px] font-mono text-muted-foreground uppercase tracking-widest">
            <span data-t="audit.feed.format">format: jsonl · ndjson</span>
            <span data-t="audit.feed.sink">→ webhooks · siem · s3</span>
          </div>
        </div>

        <!-- Subtle ambient glow behind card -->
        <div class="absolute -inset-x-8 -inset-y-12 -z-10 pointer-events-none" style="background: radial-gradient(60% 50% at 50% 50%, rgba(249,115,22,0.10), transparent 70%);"></div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Fixed-height window so the card never resizes when rows come and go.
     Height is set in JS once we've measured a real row, so it adapts to font/zoom. */
  .audit-window {
    /* Sensible fallback before JS locks the height */
    min-height: 384px;
  }
  .audit-list {
    will-change: transform;
  }

  /* Initial staggered entry of pre-rendered rows — pure fade, no layout shift */
  .audit-row {
    opacity: 0;
    animation: audit-fade-in 0.45s ease forwards;
    animation-delay: var(--row-delay, 0ms);
  }
  @keyframes audit-fade-in {
    to { opacity: 1; }
  }

  /* When JS prepends a new row it pre-positions the list one row higher and
     then animates back to translateY(0), which makes the list visibly slide
     down by exactly one row. The new row also gets a subtle primary flash. */
  .audit-row.audit-new {
    animation: audit-flash 0.9s ease-out;
  }
  @keyframes audit-flash {
    0%   { background: rgba(249, 115, 22, 0.22); }
    100% { background: transparent; }
  }

  @media (prefers-reduced-motion: reduce) {
    .audit-row,
    .audit-row.audit-new { animation: none !important; opacity: 1; transform: none; }
    .audit-list { transition: none !important; transform: none !important; }
  }
</style>

<script>
  type AuditEvent = {
    kind: keyof typeof KIND_STYLE
    message: string
    realm: string
    latency: string
  }

  const KIND_STYLE = {
    oidc:    { label: 'OIDC',    cls: 'bg-sky-500/15 text-sky-700 dark:text-sky-300 border-sky-500/30' },
    mfa:     { label: 'MFA',     cls: 'bg-emerald-500/15 text-emerald-700 dark:text-emerald-300 border-emerald-500/30' },
    token:   { label: 'TOKEN',   cls: 'bg-primary/15 text-primary border-primary/30' },
    fed:     { label: 'FED',     cls: 'bg-violet-500/15 text-violet-700 dark:text-violet-300 border-violet-500/30' },
    role:    { label: 'ROLE',    cls: 'bg-amber-500/15 text-amber-700 dark:text-amber-300 border-amber-500/30' },
    audit:   { label: 'AUDIT',   cls: 'bg-muted text-muted-foreground border' },
    passkey: { label: 'PASSKEY', cls: 'bg-fuchsia-500/15 text-fuchsia-700 dark:text-fuchsia-300 border-fuchsia-500/30' },
    warn:    { label: 'WARN',    cls: 'bg-rose-500/15 text-rose-700 dark:text-rose-300 border-rose-500/30' },
    logout:  { label: 'LOGOUT',  cls: 'bg-muted text-muted-foreground border' },
  }

  const MAX_ROWS = 8
  const TICK_MS  = 2400
  let timer: number | null = null
  let io: IntersectionObserver | null = null

  function buildRow(evt: AuditEvent): HTMLLIElement {
    const li = document.createElement('li')
    li.className = 'audit-row audit-new flex items-center gap-3 px-5 py-3 border-b border-border/50'

    const style = KIND_STYLE[evt.kind] ?? KIND_STYLE.audit
    const tag = document.createElement('span')
    tag.className =
      'shrink-0 inline-flex items-center justify-center text-[10px] font-semibold font-mono uppercase tracking-wider rounded border px-1.5 py-0.5 min-w-[56px] text-center ' +
      style.cls
    tag.textContent = style.label

    const msg = document.createElement('span')
    msg.className = 'flex-1 min-w-0 text-sm text-foreground/85 truncate'
    msg.textContent = evt.message

    const realm = document.createElement('span')
    realm.className = 'hidden sm:inline-flex items-center gap-1 text-[11px] font-mono text-muted-foreground shrink-0'
    const realmKey = document.createElement('span')
    realmKey.className = 'text-muted-foreground/70'
    realmKey.textContent = 'realm:'
    realm.appendChild(realmKey)
    realm.appendChild(document.createTextNode(evt.realm))

    const latency = document.createElement('span')
    latency.className =
      'text-[11px] font-mono shrink-0 tabular-nums ' +
      (evt.latency === 'blocked' ? 'text-rose-600 dark:text-rose-300' : 'text-foreground/60')
    latency.textContent = evt.latency

    li.append(tag, msg, realm, latency)
    return li
  }

  const SLIDE_MS = 600

  function startFeed() {
    const feed = document.getElementById('ferriskey-audit-feed') as HTMLUListElement | null
    const feedWindow = document.getElementById('ferriskey-audit-window') as HTMLDivElement | null
    if (!feed || !feedWindow) return
    const raw = feed.getAttribute('data-pool')
    if (!raw) return

    let pool: AuditEvent[]
    try { pool = JSON.parse(raw) as AuditEvent[] } catch { return }
    if (!Array.isArray(pool) || pool.length === 0) return

    let cursor = 0
    let animating = false

    // Clean up state from any previous invocation (view transitions reuse the JS module)
    if (timer !== null) { window.clearInterval(timer); timer = null }
    if (io !== null)    { io.disconnect();             io = null    }

    // Measure the natural row height and lock the window to (MAX_ROWS * rowH).
    // Robust to font scaling / zoom because we use a live measurement.
    const firstRow = feed.firstElementChild as HTMLElement | null
    const rowH = firstRow ? firstRow.offsetHeight : 48
    feedWindow.style.height = (MAX_ROWS * rowH) + 'px'

    const tick = () => {
      if (animating) return
      animating = true
      const evt = pool[cursor % pool.length]
      cursor++

      const row = buildRow(evt)
      feed.prepend(row)

      // Step 1: snap the list one row higher with no transition, so visually
      // nothing has moved yet (the new row sits just outside the window).
      feed.style.transition = 'none'
      feed.style.transform  = `translateY(-${rowH}px)`
      // Force reflow so the browser commits the above before we re-enable transitions.
      void feed.offsetHeight

      // Step 2: animate back to translateY(0). The list slides down by one row,
      // revealing the new row at the top and pushing the bottom one out of view.
      requestAnimationFrame(() => {
        feed.style.transition = `transform ${SLIDE_MS}ms cubic-bezier(0.4, 0, 0.2, 1)`
        feed.style.transform  = 'translateY(0)'
      })

      // Step 3: once the slide is done, trim any extra rows from the bottom
      // (they're already outside the visible window).
      window.setTimeout(() => {
        while (feed.children.length > MAX_ROWS) {
          feed.lastElementChild?.remove()
        }
        animating = false
      }, SLIDE_MS + 40)
    }

    // Respect reduced motion: no slide, just swap in place.
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    // Only run when visible to avoid background CPU
    io = new IntersectionObserver((entries) => {
      const visible = entries.some((e) => e.isIntersecting)
      if (visible && timer === null) {
        timer = window.setInterval(tick, TICK_MS)
      } else if (!visible && timer !== null) {
        window.clearInterval(timer)
        timer = null
      }
    }, { threshold: 0.15 })
    io.observe(feed)
  }

  startFeed()
  document.addEventListener('astro:after-swap', startFeed)
</script>
