---
import '../styles/globals.css'
import { ClientRouter } from 'astro:transitions'

interface Props {
  title: string
  description?: string
  thumbnail?: string
}

const { title, description = 'Explainer v2', thumbnail } = Astro.props
const thumbnailUrl = thumbnail ?? '/thumbnail.png'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={thumbnailUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={thumbnailUrl} />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      (function () {
        var theme = localStorage.getItem('theme') || 'system'
        var isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)
        document.documentElement.classList.toggle('dark', isDark)
      })()
    </script>
    <script is:inline>
      document.addEventListener('astro:after-swap', function () {
        var theme = localStorage.getItem('theme') || 'system'
        var isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)
        document.documentElement.classList.toggle('dark', isDark)
      })
    </script>
    <script is:inline>
      function initScrollAnim() {
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target) }
          })
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' })
        document.querySelectorAll('[data-anim]').forEach(function(el) { obs.observe(el) })
      }
      document.addEventListener('DOMContentLoaded', initScrollAnim)
      document.addEventListener('astro:after-swap', initScrollAnim)
    </script>
  </head>
  <body class="min-h-screen antialiased flex flex-col">
    <slot />
  </body>
</html>
